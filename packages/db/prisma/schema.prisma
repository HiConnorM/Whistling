// ─── Source ───────────────────────────────────────────────────────────────────

model BusinessSource {
  id                    String       @id @default(cuid())
  businessId            String
  type                  SourceType
  url                   String?
  externalId            String?
  accessTokenEncrypted  String?      @db.Text
  refreshTokenEncrypted String?      @db.Text
  tokenExpiresAt        DateTime?
  status                SourceStatus @default(PENDING)
  lastScannedAt         DateTime?
  nextScanAt            DateTime?
  cursor                String?
  errorMessage          String?
  errorCount            Int          @default(0)
  totalItemsCollected   Int          @default(0)
  metadata              Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rawItems  RawItem[]
  mentions  Mention[]
  scanJobs  ScanJob[]

  @@index([businessId])
  @@index([status])
  @@index([nextScanAt])
  @@map("business_sources")
}

enum SourceType {
  // Social & owned channels
  GOOGLE
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
  // Local & hospitality review platforms
  YELP
  TRIPADVISOR
  // Universal review platforms
  TRUSTPILOT
  // B2B review platforms
  G2
  CAPTERRA
  // Ecommerce
  AMAZON
  SHOPIFY
  // App stores
  APP_STORE
  GOOGLE_PLAY
  // Community
  REDDIT
  DISCORD
  // Internal / manual
  CSV
  WEBSITE_FORM
  EMAIL_INBOX
  SUPPORT_TICKET
  MANUAL
}

enum SourceStatus {
  CONNECTED
  NEEDS_AUTH
  ERROR
  PAUSED
  PENDING
}

// ─── Competitor ───────────────────────────────────────────────────────────────

model Competitor {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  googlePlaceId    String?
  googleUrl        String?
  yelpUrl          String?
  facebookUrl      String?
  instagramHandle  String?
  websiteUrl       String?
  city             String?
  rating           Float?
  reviewCount      Int?
  discoveryScore   Float?   // AI-ranked relevance 0–1
  isAutoDiscovered Boolean  @default(false)
  scanDepth        String   @default("LIGHT") // LIGHT | STANDARD | DEEP
  notes            String?
  isActive         Boolean  @default(true)
  lastScannedAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  mentions  Mention[]

  @@index([businessId])
  @@map("competitors")
}

// ─── Raw Item ─────────────────────────────────────────────────────────────────

model RawItem {
  id           String   @id @default(cuid())
  sourceId     String
  externalId   String
  rawJsonUrl   String?
  rawJson      Json?
  rawHtml      String?  @db.Text
  collectedAt  DateTime @default(now())
  checksum     String
  processedAt  DateTime?
  processingError String?

  source    BusinessSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  mentions  Mention[]

  @@unique([sourceId, externalId])
  @@unique([sourceId, checksum])
  @@index([sourceId])
  @@index([collectedAt])
  @@map("raw_items")
}

// ─── Mention ──────────────────────────────────────────────────────────────────

model Mention {
  id           String     @id @default(cuid())
  businessId   String
  sourceId     String
  rawItemId    String?
  competitorId String?
  externalId   String
  sourceType   SourceType
  authorName   String?
  authorId     String?
  text         String     @db.Text
  textHash     String
  rating       Float?
  url          String?
  language     String     @default("en")
  publishedAt  DateTime?
  collectedAt  DateTime   @default(now())
  isCompetitor Boolean    @default(false)
  isDuplicate  Boolean    @default(false)
  isSpam       Boolean    @default(false)

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  source      BusinessSource  @relation(fields: [sourceId], references: [id])
  rawItem     RawItem?        @relation(fields: [rawItemId], references: [id])
  competitor  Competitor?     @relation(fields: [competitorId], references: [id])
  analysis    MentionAnalysis?
  embedding   MentionEmbedding?

  @@unique([businessId, sourceType, externalId])
  @@index([businessId])
  @@index([businessId, publishedAt])
  @@index([businessId, isCompetitor])
  @@index([businessId, sourceType])
  @@index([textHash])
  @@map("mentions")
}

// ─── Mention Analysis ─────────────────────────────────────────────────────────

model MentionAnalysis {
  id              String   @id @default(cuid())
  mentionId       String   @unique
  sentiment       Sentiment
  sentimentScore  Float
  topics          String[]
  complaintTypes  String[]
  praiseTypes     String[]
  severity        Int      @db.SmallInt
  urgency         Int      @db.SmallInt
  actionability   Int      @db.SmallInt
  businessArea    String
  summary         String?  @db.Text
  isSpam          Boolean  @default(false)
  containsPII     Boolean  @default(false)
  modelVersion    String
  processedAt     DateTime @default(now())

  mention Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@index([mentionId])
  @@map("mention_analyses")
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

// ─── Mention Embedding ────────────────────────────────────────────────────────

model MentionEmbedding {
  id          String                 @id @default(cuid())
  mentionId   String                 @unique
  embedding   Unsupported("vector(1536)")?
  modelVersion String
  createdAt   DateTime               @default(now())

  mention Mention @relation(fields: [mentionId], references: [id], onDelete: Cascade)

  @@map("mention_embeddings")
}

// ─── Topic Cluster ────────────────────────────────────────────────────────────

model TopicCluster {
  id                      String          @id @default(cuid())
  businessId              String
  label                   String
  topic                   String
  sentiment               Sentiment
  isCompetitor            Boolean         @default(false)
  mentionCount            Int             @default(0)
  periodStart             DateTime
  periodEnd               DateTime
  trendDirection          TrendDirection  @default(FLAT)
  changePercent           Float           @default(0)
  representativeMentionIds String[]
  avgSeverity             Float?
  avgRating               Float?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, periodEnd])
  @@index([businessId, topic])
  @@map("topic_clusters")
}

enum TrendDirection {
  UP
  DOWN
  FLAT
}

// ─── Recommendation ───────────────────────────────────────────────────────────

model Recommendation {
  id                String                  @id @default(cuid())
  businessId        String
  reportId          String?
  title             String
  category          RecommendationCategory
  priority          RecommendationPriority  @default(MEDIUM)
  evidence          String[]
  suggestedAction   String                  @db.Text
  why               String                  @db.Text
  estimatedImpact   String
  difficulty        Difficulty              @default(MEDIUM)
  suggestedOwner    String?
  suggestedTimeline String?
  relatedTopics     String[]
  relatedMentionIds String[]
  status            RecommendationStatus    @default(NEW)
  statusNote        String?
  statusUpdatedAt   DateTime?
  generatedAt       DateTime                @default(now())
  expiresAt         DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  report   Report?  @relation(fields: [reportId], references: [id])

  @@index([businessId, status])
  @@index([businessId, priority])
  @@map("recommendations")
}

enum RecommendationCategory {
  OPERATIONS
  MARKETING
  SERVICE
  WEBSITE
  PRODUCT
  PRICING
  STAFFING
  COMPETITOR_RESPONSE
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationStatus {
  NEW
  ACCEPTED
  DISMISSED
  COMPLETED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─── Report ───────────────────────────────────────────────────────────────────

model Report {
  id              String       @id @default(cuid())
  businessId      String
  type            ReportType   @default(WEEKLY)
  periodStart     DateTime
  periodEnd       DateTime
  pulseScore      Int?
  pulsePrevious   Int?
  biggestWin      String?      @db.Text
  biggestRisk     String?      @db.Text
  bestAction      String?      @db.Text
  topPraises      Json?
  topComplaints   Json?
  customerRequests Json?
  competitorInsights Json?
  marketGaps      Json?
  emailSentAt     DateTime?
  emailSubject    String?
  status          ReportStatus @default(GENERATING)
  generatedAt     DateTime?
  createdAt       DateTime     @default(now())

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sections        ReportSection[]
  recommendations Recommendation[]

  @@index([businessId, periodEnd])
  @@index([status])
  @@map("reports")
}

enum ReportType {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ReportStatus {
  GENERATING
  READY
  SENT
  FAILED
}

model ReportSection {
  id       String @id @default(cuid())
  reportId String
  key      String
  title    String
  content  String @db.Text
  order    Int    @default(0)
  metadata Json?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_sections")
}

// ─── Pulse Score ─────────────────────────────────────────────────────────────

model PulseScore {
  id                    String   @id @default(cuid())
  businessId            String
  total                 Int
  sentimentScore        Int
  reviewVelocityScore   Int
  complaintSeverityScore Int
  responseRateScore     Int
  competitorScore       Int
  trendScore            Int
  calculatedAt          DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, calculatedAt])
  @@map("pulse_scores")
}

// ─── Scan Job ─────────────────────────────────────────────────────────────────

model ScanJob {
  id            String       @id @default(cuid())
  businessId    String
  sourceId      String?
  type          String
  status        JobStatus    @default(PENDING)
  bullJobId     String?      @unique
  itemsCollected Int         @default(0)
  itemsProcessed Int         @default(0)
  errorMessage  String?      @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  source   BusinessSource? @relation(fields: [sourceId], references: [id])

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("scan_jobs")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Usage & Billing ──────────────────────────────────────────────────────────

model UsageLedger {
  id                       String   @id @default(cuid())
  organizationId           String
  periodStart              DateTime
  periodEnd                DateTime
  // Signal counts
  collectedSignals         Int      @default(0)
  apifyRuns                Int      @default(0)
  competitorScans          Int      @default(0)
  scheduledScans           Int      @default(0)
  // AI counts
  openaiInputTokens        Int      @default(0)
  openaiOutputTokens       Int      @default(0)
  responderDrafts          Int      @default(0)
  reportsGenerated         Int      @default(0)
  // Cost tracking (USD cents)
  estimatedApifyCostCents  Int      @default(0)
  estimatedOpenAICostCents Int      @default(0)
  estimatedEmailCostCents  Int      @default(0)
  estimatedTotalCostCents  Int      @default(0)
  hardStopCents            Int
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usageEvents  UsageEvent[]

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@map("usage_ledgers")
}

model UsageEvent {
  id                 String   @id @default(cuid())
  organizationId     String
  ledgerId           String?
  businessId         String?
  sourceId           String?
  provider           String   // apify | openai | resend | internal
  eventType          String   // scan_start | signal_collected | ai_classify | ai_embed | ai_report | responder_draft | email_sent
  quantity           Int      @default(1)
  estimatedCostCents Int      @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledger       UsageLedger? @relation(fields: [ledgerId], references: [id])

  @@index([organizationId, createdAt])
  @@index([ledgerId])
  @@map("usage_events")
}

model ProviderRun {
  id                 String    @id @default(cuid())
  organizationId     String
  businessId         String
  sourceId           String?
  provider           String    @default("apify")
  actorId            String
  runId              String?   @unique
  datasetId          String?
  status             String    @default("PENDING") // PENDING | RUNNING | SUCCEEDED | FAILED
  requestedMaxItems  Int
  collectedItems     Int       @default(0)
  estimatedCostCents Int       @default(0)
  actualCostCents    Int?
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  errorMessage       String?   @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([businessId])
  @@map("provider_runs")
}

// ─── AI Responder ─────────────────────────────────────────────────────────────

model ResponderDraft {
  id             String    @id @default(cuid())
  organizationId String
  businessId     String
  mentionId      String
  sourceType     String
  reviewText     String    @db.Text
  tone           String    @default("professional") // professional | warm | playful | direct | hospitality
  generatedText  String    @db.Text
  approvedText   String?   @db.Text
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED | POSTED
  safetyFlags    String[]  // list of triggered safety rules
  brandVoice     String?   // stored brand voice prompt snippet
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  postedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([businessId])
  @@index([mentionId])
  @@map("responder_drafts")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String   // source.connected | scan.started | billing.plan_changed | responder.approved | admin.action
  resourceType   String?
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([action])
  @@map("audit_logs")
}
